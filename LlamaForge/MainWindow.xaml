<Window x:Class="LlamaForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LlamaForge.ViewModels"
        mc:Ignorable="d"
        Title="Llama Forge - Local AI Server &amp; Chat" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundPrimary}">
    <Window.DataContext>
        <local:MainViewModel/> 
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0" Background="{DynamicResource BackgroundSecondary}" Padding="20,12">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="20" Color="#000000" Opacity="0.5"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App Title with Icon -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE753;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                               Foreground="{DynamicResource AccentGradient}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="LLAMA FORGE" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}" /> <!-- LetterSpacing="2"/> -->
                        <TextBlock Text="Local AI Server &amp; Chat" FontSize="10"
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Status Message -->
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}"
                          Foreground="{DynamicResource TextSecondary}"
                          VerticalAlignment="Center"
                          Margin="40,0,0,0"
                          FontSize="13"/>

                <!-- Theme Toggle Button -->
                <Button Grid.Column="2" Width="40" Height="40" Margin="0,0,12,0"
                        Command="{Binding ToggleThemeCommand}"
                        ToolTip="Toggle Dark/Light Theme"
                        Background="{DynamicResource BackgroundCard}"
                        BorderBrush="{DynamicResource BorderPrimary}">
                    <TextBlock Text="&#xE771;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource TextPrimary}"/>
                </Button>

                <!-- Server Status -->
                <Border Grid.Column="3" Background="{DynamicResource BackgroundCard}"
                        BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1"
                        CornerRadius="20" Padding="16,8">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource ErrorColor}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource SuccessColor}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                            <Ellipse.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="8" Color="#10B981" Opacity="0.8"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock VerticalAlignment="Center" FontWeight="Medium" FontSize="13"
                                   Foreground="{DynamicResource TextPrimary}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Server Offline"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                                            <Setter Property="Text" Value="Server Online"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Margin="20,10,20,20">

            <!-- Chat Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8F2;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Chat" FontSize="14"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Chat Messages -->
                    <Border Grid.Row="0" Background="{DynamicResource BackgroundCard}"
                            BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1"
                            CornerRadius="8" Margin="0,0,0,16">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="20" Color="#000000" Opacity="0.3"/>
                        </Border.Effect>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="ChatScrollViewer" Padding="16">
                            <ItemsControl ItemsSource="{Binding ChatMessages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,16" Padding="16" CornerRadius="12">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#1E3A8A" Offset="0"/>
                                                                <GradientStop Color="#3730A3" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    <Setter Property="MaxWidth" Value="700"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUser}" Value="False">
                                                            <Setter Property="Background" Value="{DynamicResource BackgroundSecondary}"/>
                                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderPrimary}"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.Effect>
                                                <DropShadowEffect ShadowDepth="0" BlurRadius="12" Color="#0EA5E9" Opacity="0.3"/>
                                            </Border.Effect>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0"
                                                               Foreground="{DynamicResource AccentPrimary}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="&#xE77B;"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUser}" Value="False">
                                                                        <Setter Property="Text" Value="&#xE753;"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextPrimary}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="YOU"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUser}" Value="False">
                                                                        <Setter Property="Text" Value="ASSISTANT"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                                <TextBox Text="{Binding Content}" TextWrapping="Wrap" FontSize="14"
                                                         Foreground="{DynamicResource TextPrimary}"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         IsReadOnly="True"
                                                         FontFamily="Consolas"
                                                         Padding="0"
                                                         Cursor="IBeam"/>
                                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                                          FontSize="11" Foreground="{DynamicResource TextTertiary}"
                                                          Margin="0,8,0,0" FontStyle="Italic"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Input Area -->
                    <Border Grid.Row="1" Background="{DynamicResource BackgroundCard}"
                            BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1"
                            CornerRadius="8" Padding="16">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="20" Color="#000000" Opacity="0.3"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
                                     Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     IsEnabled="{Binding IsServerRunning}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Modifiers="Control" Command="{Binding SendMessageCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>

                            <Button Grid.Column="1" Width="100" Height="60" Margin="12,0,0,0"
                                    Command="{Binding SendMessageCommand}"
                                    Style="{StaticResource SuccessButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="Send" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2" Width="100" Height="60" Margin="12,0,0,0"
                                    Command="{Binding ClearChatCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="Clear" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Server Control Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Server" FontSize="14"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                    <!-- Variant Selection -->
                    <GroupBox Grid.Row="0" Margin="0,0,0,16">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"
                                          Foreground="{DynamicResource AccentPurple}"/>
                                <TextBlock Text="Select llama.cpp Variant" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </GroupBox.Header>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ComboBox Grid.Row="0" ItemsSource="{Binding AvailableVariants}"
                                      SelectedItem="{Binding SelectedVariant}"
                                      DisplayMemberPath="DisplayName"
                                      Height="40" Margin="0,0,0,12"
                                      Foreground="{DynamicResource TextPrimary}"
                                      IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>

                            <TextBlock Grid.Row="1" Text="{Binding SelectedVariant.Description}"
                                       TextWrapping="Wrap" FontStyle="Italic"
                                       Foreground="{DynamicResource TextSecondary}" LineHeight="20"/>
                        </Grid>
                    </GroupBox>

                    <!-- Server Configuration -->
                    <GroupBox Grid.Row="1" Margin="0,0,0,16">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE115;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"
                                          Foreground="{DynamicResource AccentPrimary}"/>
                                <TextBlock Text="Server Configuration" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </GroupBox.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Model File:" VerticalAlignment="Center"
                                       Margin="0,0,0,12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ModelPath}" Margin="0,0,12,12"
                                     IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>
                            <Button Grid.Row="0" Grid.Column="2" Command="{Binding BrowseModelCommand}" Margin="0,0,0,12"
                                    IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="Browse" FontSize="13"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Host:" VerticalAlignment="Center"
                                       Margin="0,0,0,12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Host}" Margin="0,0,0,12"
                                     IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Port:" VerticalAlignment="Center"
                                       Margin="0,0,0,12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Port}" Margin="0,0,0,12"
                                     IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Context Size:" VerticalAlignment="Center"
                                       Margin="0,0,0,12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding ContextSize}" Margin="0,0,0,12"
                                     IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Threads:" VerticalAlignment="Center"
                                       Margin="0,0,0,12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Threads}" Margin="0,0,0,12"
                                     IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="GPU Layers:" VerticalAlignment="Center"
                                       Margin="0,0,0,12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding GpuLayers}" Margin="0,0,0,12"
                                     IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Additional Args:" VerticalAlignment="Center"
                                       FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding AdditionalArgs}"
                                     IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>
                        </Grid>
                    </GroupBox>

                    <!-- Server Controls -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Width="160" Height="48" Margin="0,0,16,0"
                                Command="{Binding StartServerCommand}"
                                Style="{StaticResource SuccessButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Start Server" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button Width="160" Height="48"
                                Command="{Binding StopServerCommand}"
                                Style="{StaticResource ErrorButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Stop Server" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Server Logs -->
                    <GroupBox Grid.Row="3">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"
                                          Foreground="{DynamicResource AccentCyan}"/>
                                <TextBlock Text="Server Logs" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </GroupBox.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Height="400"
                                     Padding="0,0,0,16">
                            <ItemsControl ItemsSource="{Binding ServerLogs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Mode=OneWay}"
                                                 FontFamily="Consolas"
                                                 FontSize="12"
                                                 Foreground="{DynamicResource TextPrimary}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 IsReadOnly="True"
                                                 TextWrapping="NoWrap"
                                                 Margin="0,2"
                                                 Cursor="IBeam"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </GroupBox>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Download Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Download / Update" FontSize="14"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Download Controls -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Width="180" Height="48" Margin="0,0,16,0"
                                Command="{Binding CheckUpdatesCommand}"
                                Style="{StaticResource AccentButton}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Check for Updates" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button Width="180" Height="48"
                                Command="{Binding DownloadVariantCommand}"
                                Style="{StaticResource WarningButton}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Download Selected" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Available Variants List -->
                    <GroupBox Grid.Row="1">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"
                                          Foreground="{DynamicResource AccentCyan}"/>
                                <TextBlock Text="Available Variants" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </GroupBox.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding DownloadableVariants}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BackgroundCard}"
                                                BorderBrush="{DynamicResource BorderPrimary}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="16"
                                                Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Checkbox and Variant Name -->
                                                <CheckBox Grid.Row="0" Grid.Column="0"
                                                          IsChecked="{Binding IsSelected}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,12,0"/>
                                                <StackPanel Grid.Row="0" Grid.Column="1">
                                                    <TextBlock Text="{Binding Variant.DisplayName}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock Text="{Binding Variant.Description}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>

                                                <!-- Version Info -->
                                                <Grid Grid.Row="1" Grid.Column="1" Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <TextBlock Text="Installed: " FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                                        <TextBlock Text="{Binding InstalledVersion}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                                                        <TextBlock Text="Latest: " FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                                        <TextBlock Text="{Binding LatestVersion}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource AccentPrimary}"/>
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding StatusMessage}"
                                                               FontSize="12"
                                                               FontStyle="Italic"
                                                               Foreground="{DynamicResource TextTertiary}"/>
                                                </Grid>

                                                <!-- Progress Bar -->
                                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,8,0,0"
                                                            Visibility="{Binding IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <ProgressBar Height="8"
                                                                 Value="{Binding DownloadProgress}"
                                                                 Maximum="100"
                                                                 Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding DownloadProgress, StringFormat='{}Downloading: {0}%'}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource AccentPrimary}"
                                                               HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- About Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="About" FontSize="14"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                    <StackPanel Margin="0,0,16,0">
                        <!-- Header Card -->
                        <Border Background="{DynamicResource BackgroundCard}"
                                BorderBrush="{DynamicResource BorderAccent}" BorderThickness="2"
                                CornerRadius="12" Padding="32" Margin="0,0,0,24">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="30" Color="#0EA5E9" Opacity="0.4"/>
                            </Border.Effect>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="&#xE753;" FontFamily="Segoe MDL2 Assets" FontSize="64"
                                          Foreground="{DynamicResource AccentGradient}"
                                          HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                <TextBlock Text="LLAMA FORGE" FontSize="32" FontWeight="Bold"
                                          Foreground="{DynamicResource TextPrimary}" 
                                          HorizontalAlignment="Center"/>
                                <TextBlock Text="A Modern WPF Wrapper for llama.cpp" FontSize="16"
                                          Foreground="{DynamicResource TextSecondary}" Margin="0,8,0,0"
                                          HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Features Card -->
                        <GroupBox Margin="0,0,0,24">
                            <GroupBox.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="0,0,10,0"
                                              Foreground="{DynamicResource AccentPrimary}"/>
                                    <TextBlock Text="Features" FontSize="18" FontWeight="SemiBold"/>
                                </StackPanel>
                            </GroupBox.Header>
                            <StackPanel>
                                <Border Background="{DynamicResource BackgroundSecondary}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="16"
