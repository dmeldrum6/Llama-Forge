<UserControl x:Class="LlamaForge.Controls.MessageContentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:LlamaForge.Controls"
             xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <ItemsControl x:Name="ContentItemsControl">
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <ContentPresenter Content="{Binding}">
                    <ContentPresenter.Resources>
                        <!-- Template for regular text blocks -->
                        <DataTemplate DataType="{x:Type local:TextBlock}">
                            <TextBlock Text="{Binding Text}"
                                       TextWrapping="Wrap"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,0,0,8"/>
                        </DataTemplate>

                        <!-- Template for code blocks -->
                        <DataTemplate DataType="{x:Type local:CodeBlock}">
                            <Border Background="#1E1E1E"
                                    CornerRadius="6"
                                    Padding="12"
                                    Margin="0,4,0,8"
                                    BorderBrush="{DynamicResource BorderPrimary}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Language label -->
                                    <TextBlock Grid.Row="0"
                                               Text="{Binding Language}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="#6B7280"
                                               Margin="0,0,0,8"
                                               Visibility="{Binding HasLanguage, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Code editor -->
                                    <avalonEdit:TextEditor Grid.Row="1"
                                                          x:Name="CodeEditor"
                                                          FontFamily="Consolas"
                                                          FontSize="13"
                                                          IsReadOnly="True"
                                                          ShowLineNumbers="False"
                                                          WordWrap="True"
                                                          Background="Transparent"
                                                          Foreground="#D4D4D4"
                                                          Document="{Binding Document, Mode=OneWay}"
                                                          SyntaxHighlighting="{Binding SyntaxHighlighting, Mode=OneWay}"
                                                          VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Auto"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ContentPresenter.Resources>
                </ContentPresenter>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
