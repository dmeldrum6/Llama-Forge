<Window x:Class="LlamaForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LlamaForge.ViewModels"
        xmlns:controls="clr-namespace:LlamaForge.Controls"
        mc:Ignorable="d"
        Title="Llama Forge - Local AI Server" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundPrimary}">
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0" Background="{DynamicResource BackgroundSecondary}" Padding="20,12">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="20" Color="#000000" Opacity="0.5"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App Title with Icon -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE82A;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                               Foreground="{DynamicResource AccentGradient}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="LLAMA FORGE" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}" /> <!-- LetterSpacing="2"/> -->
                        <TextBlock Text="Local AI Server" FontSize="10"
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Status Message -->
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}"
                          Foreground="{DynamicResource TextSecondary}"
                          VerticalAlignment="Center"
                          Margin="40,0,0,0"
                          FontSize="13"/>

                <!-- Theme Toggle Button -->
                <Button Grid.Column="2" Width="40" Height="40" Margin="0,0,12,0"
                        Command="{Binding ToggleThemeCommand}"
                        ToolTip="Toggle Dark/Light Theme"
                        Background="{DynamicResource BackgroundCard}"
                        BorderBrush="{DynamicResource BorderPrimary}">
                    <TextBlock Text="&#xE771;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource TextPrimary}"/>
                </Button>

                <!-- Server Status -->
                <Border Grid.Column="3" Background="{DynamicResource BackgroundCard}"
                        BorderBrush="{DynamicResource BorderPrimary}" BorderThickness="1"
                        CornerRadius="20" Padding="16,8">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource ErrorColor}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource SuccessColor}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                            <Ellipse.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="8" Color="#10B981" Opacity="0.8"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock VerticalAlignment="Center" FontWeight="Medium" FontSize="13"
                                   Foreground="{DynamicResource TextPrimary}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Server Offline"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                                            <Setter Property="Text" Value="Server Online"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Margin="20,10,20,20">

            <!-- Server Control Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Server" FontSize="14"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                    <!-- Server Controls -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Width="160" Height="48" Margin="0,0,16,0"
                                Command="{Binding StartServerCommand}"
                                Style="{StaticResource SuccessButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Start Server" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button Width="160" Height="48" Margin="0,0,16,0"
                                Command="{Binding StopServerCommand}"
                                Style="{StaticResource ErrorButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Stop Server" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button Width="180" Height="48"
                                Command="{Binding OpenBrowserCommand}"
                                Style="{StaticResource AccentButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Launch Chat Client" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Variant Selection -->
                    <Expander Grid.Row="1" Margin="0,0,0,16" IsExpanded="True">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"
                                          Foreground="{DynamicResource AccentPurple}"/>
                                <TextBlock Text="Select llama.cpp Variant" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                            </StackPanel>
                        </Expander.Header>
                        <Grid Margin="16,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ComboBox Grid.Row="0" ItemsSource="{Binding AvailableVariants}"
                                      SelectedItem="{Binding SelectedVariant}"
                                      DisplayMemberPath="DisplayName"
                                      Height="40" Margin="0,0,0,12"
                                      Foreground="{DynamicResource BackgroundPrimary}"
                                      IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>

                            <TextBlock Grid.Row="1" Text="{Binding SelectedVariant.Description}"
                                       TextWrapping="Wrap" FontStyle="Italic"
                                       Foreground="{DynamicResource TextSecondary}" LineHeight="20"/>
                        </Grid>
                    </Expander>

                    <!-- Model Information (shown when server is running) -->
                    <Expander Grid.Row="2" Margin="0,0,0,16" IsExpanded="True" Visibility="{Binding HasModelInfo, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"
                                          Foreground="{DynamicResource AccentPrimary}"/>
                                <TextBlock Text="Model Information" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Expander.Header>
                        <Grid Margin="16,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Model Name:" Margin="0,0,0,8" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentModelInfo.Name}" Margin="0,0,0,8" Foreground="{DynamicResource TextPrimary}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Architecture:" Margin="0,0,0,8" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentModelInfo.Architecture}" Margin="0,0,0,8" Foreground="{DynamicResource TextPrimary}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Size:" Margin="0,0,0,8" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentModelInfo.SizeLabel}" Margin="0,0,0,8" Foreground="{DynamicResource TextPrimary}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Vocabulary:" Margin="0,0,0,8" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CurrentModelInfo.Meta.VocabSize, StringFormat='{}{0:N0} tokens'}" Margin="0,0,0,8" Foreground="{DynamicResource TextPrimary}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Training Context:" Margin="0,0,0,8" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CurrentModelInfo.Meta.TrainingContextLength, StringFormat='{}{0:N0} tokens'}" Margin="0,0,0,8" Foreground="{DynamicResource TextPrimary}"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Embedding Size:" Margin="0,0,0,8" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding CurrentModelInfo.Meta.EmbeddingDimensions}" Margin="0,0,0,8" Foreground="{DynamicResource TextPrimary}"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="License:" Margin="0,0,0,8" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding CurrentModelInfo.License}" Margin="0,0,0,8" Foreground="{DynamicResource TextPrimary}"/>
                        </Grid>
                    </Expander>

                    <!-- Basic Configuration -->
                    <Expander Grid.Row="3" Margin="0,0,0,16" IsExpanded="True">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE115;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"
                                          Foreground="{DynamicResource AccentPrimary}"/>
                                <TextBlock Text="Basic Configuration" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                            </StackPanel>
                        </Expander.Header>
                        <Grid Margin="16,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Model File:" VerticalAlignment="Center"
                                       Margin="0,0,0,12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"
                                       ToolTip="Path to the GGUF model file"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ModelPath}" Margin="0,0,12,12"
                                     IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>
                            <Button Grid.Row="0" Grid.Column="2" Command="{Binding BrowseModelCommand}" Margin="0,0,0,12"
                                    IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="Browse" FontSize="13"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Host:" VerticalAlignment="Center"
                                       Margin="0,0,0,12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"
                                       ToolTip="Network address to listen on (default: 127.0.0.1)"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Host}" Margin="0,0,0,12"
                                     IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Port:" VerticalAlignment="Center"
                                       Margin="0,0,0,12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"
                                       ToolTip="Network port to listen on (default: 8080)"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Port}" Margin="0,0,0,12"
                                     IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Context Size:" VerticalAlignment="Center"
                                       Margin="0,0,0,12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"
                                       ToolTip="Token context window size (default: 2048)"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding ContextSize}" Margin="0,0,0,12"
                                     IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Model Alias:" VerticalAlignment="Center"
                                       Margin="0,0,0,0" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"
                                       ToolTip="Friendly name returned in API responses (optional)"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding ModelAlias}" Margin="0,0,0,0"
                                     IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>
                        </Grid>
                    </Expander>

                    <!-- Performance Settings -->
                    <Expander Grid.Row="4" Margin="0,0,0,16" IsExpanded="False">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"
                                          Foreground="{DynamicResource AccentCyan}"/>
                                <TextBlock Text="Performance Settings" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                            </StackPanel>
                        </Expander.Header>
                        <Grid Margin="16,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Threads:" VerticalAlignment="Center"
                                       Margin="0,0,0,12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"
                                       ToolTip="Number of CPU threads for generation (default: 4)"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Threads}" Margin="0,0,12,12"
                                     IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>
                            <Button Grid.Row="0" Grid.Column="2" Command="{Binding AutoDetectThreadsCommand}" Margin="0,0,0,12"
                                    IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="Auto-Detect" FontSize="13"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Batch Threads:" VerticalAlignment="Center"
                                       Margin="0,0,0,12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"
                                       ToolTip="Threads for batch/prompt processing (default: 4)"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding BatchThreads}" Margin="0,0,0,12"
                                     IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Batch Size:" VerticalAlignment="Center"
                                       Margin="0,0,0,12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"
                                       ToolTip="Batch size for prompt processing (default: 512)"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding BatchSize}" Margin="0,0,0,12"
                                     IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Parallel Slots:" VerticalAlignment="Center"
                                       Margin="0,0,0,12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"
                                       ToolTip="Number of parallel request slots (default: 1)"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding ParallelSlots}" Margin="0,0,0,12"
                                     IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Continuous Batching:" VerticalAlignment="Center"
                                       Margin="0,0,0,12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"
                                       ToolTip="Enable dynamic batching for improved throughput"/>
                            <CheckBox Grid.Row="4" Grid.Column="1" IsChecked="{Binding ContinuousBatching}" Margin="0,0,0,12"
                                      VerticalAlignment="Center"
                                      IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="GPU Layers:" VerticalAlignment="Center"
                                       Margin="0,0,0,12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"
                                       ToolTip="Number of layers to offload to GPU (0 = CPU only)"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding GpuLayers}" Margin="0,0,0,12"
                                     IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Timeout (seconds):" VerticalAlignment="Center"
                                       Margin="0,0,0,0" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"
                                       ToolTip="Read/write timeout in seconds (default: 600)"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Timeout}" Margin="0,0,0,0"
                                     IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>
                        </Grid>
                    </Expander>

                    <!-- Memory Management -->
                    <Expander Grid.Row="5" Margin="0,0,0,16" IsExpanded="False">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"
                                          Foreground="{DynamicResource AccentCyan}"/>
                                <TextBlock Text="Memory Management" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                            </StackPanel>
                        </Expander.Header>
                        <Grid Margin="16,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Lock Model in Memory (mlock):" VerticalAlignment="Center"
                                       Margin="0,0,0,12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"
                                       ToolTip="Prevent model from being swapped to disk (improves latency)"/>
                            <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding MemoryLock}" Margin="0,0,0,12"
                                      VerticalAlignment="Center"
                                      IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Disable Memory Mapping (no-mmap):" VerticalAlignment="Center"
                                       Margin="0,0,0,0" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"
                                       ToolTip="Force loading model into RAM instead of memory-mapping"/>
                            <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding DisableMemoryMapping}" Margin="0,0,0,0"
                                      VerticalAlignment="Center"
                                      IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>
                        </Grid>
                    </Expander>

                    <!-- System Prompt -->
                    <Expander Grid.Row="6" Margin="0,0,0,16" IsExpanded="True">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8F2;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"
                                          Foreground="{DynamicResource AccentPurple}"/>
                                <TextBlock Text="System Prompt" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                            </StackPanel>
                        </Expander.Header>
                        <Grid Margin="16,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Define the AI assistant's behavior and personality:"
                                       Margin="0,0,0,8" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBox Grid.Row="1" Text="{Binding SystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                                     Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     IsEnabled="{Binding IsServerRunning, Converter={StaticResource InverseBooleanConverter}}"/>
                        </Grid>
                    </Expander>

                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Server Logs Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Server Logs" FontSize="14"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="0,16,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Padding="0,0,16,16">
                        <ItemsControl ItemsSource="{Binding ServerLogs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Mode=OneWay}"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             Foreground="{DynamicResource TextPrimary}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             IsReadOnly="True"
                                             TextWrapping="NoWrap"
                                             Margin="0,2"
                                             Cursor="IBeam"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Download Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Download / Update" FontSize="14"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Download Controls -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Width="180" Height="48" Margin="0,0,16,0"
                                Command="{Binding CheckUpdatesCommand}"
                                Style="{StaticResource AccentButton}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Check for Updates" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button Width="180" Height="48"
                                Command="{Binding DownloadVariantCommand}"
                                Style="{StaticResource WarningButton}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Download Selected" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Available Variants List -->
                    <GroupBox Grid.Row="1">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"
                                          Foreground="{DynamicResource AccentCyan}"/>
                                <TextBlock Text="Available Variants" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </GroupBox.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding DownloadableVariants}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BackgroundCard}"
                                                BorderBrush="{DynamicResource BorderPrimary}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="16"
                                                Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Checkbox and Variant Name -->
                                                <CheckBox Grid.Row="0" Grid.Column="0"
                                                          IsChecked="{Binding IsSelected}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,12,0"/>
                                                <StackPanel Grid.Row="0" Grid.Column="1">
                                                    <TextBlock Text="{Binding Variant.DisplayName}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock Text="{Binding Variant.Description}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>

                                                <!-- Version Info -->
                                                <Grid Grid.Row="1" Grid.Column="1" Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <TextBlock Text="Installed: " FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                                        <TextBlock Text="{Binding InstalledVersion}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                                                        <TextBlock Text="Latest: " FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                                        <TextBlock Text="{Binding LatestVersion}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource AccentPrimary}"/>
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding StatusMessage}"
                                                               FontSize="12"
                                                               FontStyle="Italic"
                                                               Foreground="{DynamicResource TextTertiary}"/>
                                                </Grid>

                                                <!-- Progress Bar -->
                                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,8,0,0"
                                                            Visibility="{Binding IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <ProgressBar Height="8"
                                                                 Value="{Binding DownloadProgress}"
                                                                 Maximum="100"
                                                                 Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding DownloadProgress, StringFormat='{}Downloading: {0}%'}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource AccentPrimary}"
                                                               HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- About Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="About" FontSize="14"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                    <StackPanel Margin="0,0,16,0">
                        <!-- Header Card -->
                        <Border Background="{DynamicResource BackgroundCard}"
                                BorderBrush="{DynamicResource BorderAccent}" BorderThickness="2"
                                CornerRadius="12" Padding="32" Margin="0,0,0,24">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="30" Color="#0EA5E9" Opacity="0.4"/>
                            </Border.Effect>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="&#xE82A;" FontFamily="Segoe MDL2 Assets" FontSize="128"
                                          Foreground="{DynamicResource AccentGradient}"
                                          HorizontalAlignment="Center" Margin="0,0,0,-50"/>
                                <TextBlock Text="LLAMA FORGE" FontSize="32" FontWeight="Bold"
                                          Foreground="{DynamicResource TextPrimary}" 
                                          HorizontalAlignment="Center"/>
                                <TextBlock Text="A Modern WPF Wrapper for llama.cpp" FontSize="16"
                                          Foreground="{DynamicResource TextSecondary}" Margin="0,8,0,0"
                                          HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Features Card -->
                        <GroupBox Margin="0,0,0,24">
                            <GroupBox.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="0,0,10,0"
                                              Foreground="{DynamicResource AccentPrimary}"/>
                                    <TextBlock Text="Features" FontSize="18" FontWeight="SemiBold"/>
                                </StackPanel>
                            </GroupBox.Header>
                            <StackPanel>
                                <Border Background="{DynamicResource BackgroundSecondary}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                  Foreground="{DynamicResource AccentCyan}" Margin="0,0,12,0"/>
                                        <TextBlock Text="Download and manage multiple llama.cpp variants (CPU, CUDA, ROCm, Vulkan, etc.)"
                                                  TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}" LineHeight="22"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="{DynamicResource BackgroundSecondary}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                  Foreground="{StaticResource SuccessColor}" Margin="0,0,12,0"/>
                                        <TextBlock Text="Start and stop local llama.cpp server with easy configuration"
                                                  TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}" LineHeight="22"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="{DynamicResource BackgroundSecondary}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                  Foreground="{DynamicResource AccentPurple}" Margin="0,0,12,0"/>
                                        <TextBlock Text="OpenAI-compatible API server with web-based chat interface"
                                                  TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}" LineHeight="22"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="{DynamicResource BackgroundSecondary}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                  Foreground="{DynamicResource AccentSecondary}" Margin="0,0,12,0"/>
                                        <TextBlock Text="Automatic update detection from GitHub"
                                                  TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}" LineHeight="22"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="{DynamicResource BackgroundSecondary}" CornerRadius="6" Padding="12">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                  Foreground="{StaticResource WarningColor}" Margin="0,0,12,0"/>
                                        <TextBlock Text="Real-time server monitoring and logging"
                                                  TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}" LineHeight="22"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </GroupBox>

                        <!-- Quick Start Card -->
                        <GroupBox Margin="0,0,0,24">
                            <GroupBox.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="0,0,10,0"
                                              Foreground="{StaticResource SuccessColor}"/>
                                    <TextBlock Text="Quick Start Guide" FontSize="18" FontWeight="SemiBold"/>
                                </StackPanel>
                            </GroupBox.Header>
                            <StackPanel>
                                <TextBlock Text="1. Go to the Download / Update tab" Margin="0,0,0,8"
                                          Foreground="{DynamicResource TextPrimary}" FontSize="14"/>
                                <TextBlock Text="2. Select a variant (e.g., CUDA for NVIDIA GPUs, CPU for CPU-only)" Margin="0,0,0,8"
                                          Foreground="{DynamicResource TextPrimary}" FontSize="14"/>
                                <TextBlock Text="3. Click Download Selected to download llama.cpp" Margin="0,0,0,8"
                                          Foreground="{DynamicResource TextPrimary}" FontSize="14"/>
                                <TextBlock Text="4. Go to the Server tab" Margin="0,0,0,8"
                                          Foreground="{DynamicResource TextPrimary}" FontSize="14"/>
                                <TextBlock Text="5. Browse and select a GGUF model file" Margin="0,0,0,8"
                                          Foreground="{DynamicResource TextPrimary}" FontSize="14"/>
                                <TextBlock Text="6. Configure server settings (GPU layers, context size, etc.)" Margin="0,0,0,8"
                                          Foreground="{DynamicResource TextPrimary}" FontSize="14"/>
                                <TextBlock Text="7. Click Start Server" Margin="0,0,0,8"
                                          Foreground="{DynamicResource TextPrimary}" FontSize="14"/>
                                <TextBlock Text="8. Click Launch Chat Client to open the web interface in your browser!" Margin="0,0,0,0"
                                          Foreground="{DynamicResource AccentPrimary}" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Tips Card -->
                        <GroupBox Margin="0,0,0,24">
                            <GroupBox.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE82F;" FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="0,0,10,0"
                                              Foreground="{StaticResource WarningColor}"/>
                                    <TextBlock Text="Tips &amp; Tricks" FontSize="18" FontWeight="SemiBold"/>
                                </StackPanel>
                            </GroupBox.Header>
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Margin="0,0,0,8" Foreground="{DynamicResource TextPrimary}" LineHeight="22">
                                    <Run Text="•" FontWeight="Bold" Foreground="{DynamicResource AccentPrimary}"/>
                                    <Run Text=" Click Launch Chat Client to open the web interface in your default browser"/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" Margin="0,0,0,8" Foreground="{DynamicResource TextPrimary}" LineHeight="22">
                                    <Run Text="•" FontWeight="Bold" Foreground="{DynamicResource AccentPrimary}"/>
                                    <Run Text=" GPU Layers: Set to 0 for CPU-only, or higher values to offload layers to GPU"/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" Margin="0,0,0,8" Foreground="{DynamicResource TextPrimary}" LineHeight="22">
                                    <Run Text="•" FontWeight="Bold" Foreground="{DynamicResource AccentPrimary}"/>
                                    <Run Text=" Context Size: Larger values use more memory but allow longer conversations"/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}" LineHeight="22">
                                    <Run Text="•" FontWeight="Bold" Foreground="{DynamicResource AccentPrimary}"/>
                                    <Run Text=" Check the Server Logs for detailed information about server status"/>
                                </TextBlock>
                            </StackPanel>
                        </GroupBox>

                        <!-- Links Card -->
                        <GroupBox>
                            <GroupBox.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="0,0,10,0"
                                              Foreground="{DynamicResource AccentSecondary}"/>
                                    <TextBlock Text="Useful Links" FontSize="18" FontWeight="SemiBold"/>
                                </StackPanel>
                            </GroupBox.Header>
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Margin="0,0,0,8" Foreground="{DynamicResource TextPrimary}">
                                    <Run Text="llama.cpp:" FontWeight="SemiBold"/>
                                    <Run Text=" https://github.com/ggerganov/llama.cpp" Foreground="{DynamicResource AccentCyan}"/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}">
                                    <Run Text="Models:" FontWeight="SemiBold"/>
                                    <Run Text=" https://huggingface.co/models?search=gguf" Foreground="{DynamicResource AccentCyan}"/>
                                </TextBlock>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
